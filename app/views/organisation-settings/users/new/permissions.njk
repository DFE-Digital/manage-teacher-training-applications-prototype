{% extends "_content-wide.njk" %}

{% set primaryNavId = 'users' %}

{% set title = 'User permissions - Add user' %}

{% set backLinkUrl %}/organisation-settings/{{org.id}}/users/new{% endset %}
{% set cancelLinkUrl %}/organisation-settings/{{org.id}}/users{% endset %}

{% block beforeContent %}
  {{ govukBackLink({
    href: backLinkUrl
  }) }}
{% endblock %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {# <h1 class="govuk-heading-l"> #}
      {% set h1 %}
        <span class="govuk-caption-l">
          Add user - {{org.name}}
        </span>
        User permissions
      {% endset %}
      {# </h1> #}

      {# {% include "_includes/users/organisational-permissions-content.njk" %} #}

      {% set partnersCheckboxes %}
        {{ govukCheckboxes({
          idPrefix: "blah",
          name: "blah",
          fieldset: {
            legend: {
              text: "Partners",
              classes: "govuk-fieldset__legend--s"
            }
          },
          items: [
            {
              value: "UCL, University College London",
              text: "UCL, University College London"
            },
            {
              value: "Goldsmiths, University of London",
              text: "Goldsmiths, University of London"
            }
          ]
        }) }}
      {% endset %}

      <form novalidate method="post">
        {{ govukCheckboxes({
          fieldset: {
            legend: {
              html: h1,
              isPageHeading: true,
              classes: "govuk-fieldset__legend--l"
            }
          },
          hint: {
              text: "All users can view applications."
            },
          items: [
            {
              value: "manageUsers",
              text: "Manage users"
            },
            {
              value: "manageOrganisation",
              text: "Manage organisation permissions"
            },
            {
              value: "setupInterviews",
              html: "Manage interviews"
            },
            {
              value: "makeDecisions",
              html: "Make offers and reject applications",
              conditional: {
                html: partnersCheckboxes
              }
            },
            {
              value: "viewSafeguardingInformation",
              text: "View criminal record and professional misconduct information"
            },
            {
              value: "viewDiversityInformation",
              text: "View sex, disability and ethnicity information"
            }
          ]
        } | decorateAttributes(data, 'data.newuser.permissions')) }}

        {{govukButton({
          text: "Continue"
        })}}
      </form>
      <p class="govuk-body"><a href="{{cancelLinkUrl}}">Cancel</a></p>
    </div>
  </div>

{% endblock %}
