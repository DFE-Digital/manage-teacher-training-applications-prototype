{% extends "_layout.njk" %}

{% set primaryNavId = 'applications' %}
{% set name = application.personalDetails.name %}

{% if application.status == "Rejected" %}
  {% set caption = content.giveFeedback.caption + ' - ' + name %}
  {% set heading = "Reasons the application was rejected" %}
{% else %}
  {% set caption = content.rejectApplication.caption + ' - ' + name %}
  {% set heading = "Reasons for rejecting the application" %}
{% endif %}
{% set title = heading + ' - ' + caption %}

{% block pageNavigation %}
  {% set backUrl = "/applications/" + application.id + "/decision" %}
  {% if application.status == "Rejected" %}
    {% set backUrl = "/applications/" + application.id %}
  {% endif %}

  {{ govukBackLink({
    href: backUrl
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% set h1 %}
        <span class="govuk-caption-l">{{caption}}</span>
        {{heading}}
      {% endset %}

      <form method="post">

      <h1 class="govuk-heading-l">ITT criteria</h1>

      <p class="govuk-body">If you are unsure whether the candidate’s qualifications meet the ITT criteria...</p>


{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{{ govukCheckboxes({
  name: "waste",
  fieldset: {
    legend: {
      text: "Why are you rejecting them?",
      isPageHeading: true,
      classes: "govuk-fieldset__legend--m"
    }
  },
  items: [
    {
      value: "carcasses",
      text: "They don’t have a degree or equivalent"
    },
    {
      value: "mines",
      text: "They don’t meet the maths standard of GCSE C/4"
    },
    {
      value: "farm",
      text: "They don’t meet the science standard of GCSE C/4"
    },
    {
      value: "farm",
      text: "They don’t meet the English standard of GCSE C/4"
    },
    {
      divider: "or"
    }
    ,
    {
      value: "farm",
      text: "They meet the ITT criteria but I’m rejecting them for another reason"
    }

  ]
}) }}

{#

      <h1 class="govuk-heading-l">Degree</h1>

      <p class="govuk-body">{{ name }} has these degrees:</p>

      {% include "_includes/applications/degrees.njk" %}

      {% from "govuk/components/radios/macro.njk" import govukRadios %}

      {{ govukRadios({
        name: "degree",
        fieldset: {
          legend: {
            text: "Do they have an equivalent of a bachelors degree?",
            isPageHeading: true,
            classes: "govuk-fieldset__legend--m"
          }
        },
        items: [
          {
            value: "england",
            text: "Yes"
          },
          {
            value: "scotland",
            text: "No"
          },
          {
            value: "wales",
            text: "I’m not sure"
          }
        ]
      }) }} #}

        {{ govukButton({
          text: "Continue"
        }) }}
      </form>

      <p class="govuk-body"><a class="govuk-link--no-visited-state" href="/applications/{{ application.id }}">Cancel</a></p>
    </div>
  </div>
{% endblock %}
